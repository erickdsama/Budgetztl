NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# Called "Publishable Key" in newer Supabase dashboards
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# For type generation only (pnpm db:types)
SUPABASE_PROJECT_ID=your-project-id

# Site URL — used for OAuth redirects (set in .env.local for dev, Vercel env for prod)
# Dev: http://localhost:3001
# Prod: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Supabase service role key — used by cron job only (never expose to client)
# Found in Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron job secret — Vercel sends this as Authorization: Bearer <secret>
# Generate with: openssl rand -hex 32
# Set in Vercel Dashboard → Settings → Environment Variables
CRON_SECRET=your-random-secret
